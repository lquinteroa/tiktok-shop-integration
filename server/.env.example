# TikTok Shop App Credentials (from Partner Center)
APP_KEY=APP_KEY
APP_SECRET=APP_SECRET

# OAuth Redirect URI — update this each time ngrok gives you a new URL
# (or use a paid ngrok plan for a stable domain)
REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/callback

# Frontend URL (for CORS + post-auth redirect)
FRONTEND_URL=http://localhost:3000

# ngrok Auth Token — get yours free at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=TOKEN

# Server
PORT=3001
