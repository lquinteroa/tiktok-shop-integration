# TikTok Shop App Credentials (from Partner Center)
APP_KEY=your_app_key_here
APP_SECRET=your_app_secret_here

# PostgreSQL connection string — get this free from Neon: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OAuth Redirect URI
# Local dev: updated automatically by scripts/dev.js each time ngrok starts
# Production: https://your-app.onrender.com/auth/callback
REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/callback

# Frontend URL (for CORS + post-auth redirect)
# Local: http://localhost:3000  |  Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ngrok Auth Token — free at https://dashboard.ngrok.com (local dev only)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Local Auth (single-user JWT)
# Generate a bcrypt hash for your password by running in server/:
#   node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# JWT secret — any long random string, generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Server
PORT=3001
